{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/",
      "dest": "/simple-login.html"
    },
    {
      "src": "/login",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/students",
      "dest": "/frontend/students-enhanced.html"
    },
    {
      "src": "/courses",
      "dest": "/courses.html"
    },
    {
      "src": "/simple-login.html",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard-fixed.html",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/courses.html",
      "dest": "/courses.html"
    },
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/backend/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
