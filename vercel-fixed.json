{
  "version": 2,
  "name": "campus-connect",
  "builds": [
    {
      "src": "dashboard-fixed.html",
      "use": "@vercel/static"
    },
    {
      "src": "simple-login.html",
      "use": "@vercel/static"
    },
    {
      "src": "courses.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/simple-login.html"
    },
    {
      "src": "/login",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/courses",
      "dest": "/courses.html"
    },
    {
      "src": "/students",
      "dest": "/frontend/students-enhanced.html"
    },
    {
      "src": "/simple-login.html",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard-fixed.html",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/courses.html",
      "dest": "/courses.html"
    },
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/backend/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
