{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/",
      "dest": "/simple-login.html"
    },
    {
      "src": "/login",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/students",
      "dest": "/frontend/students-enhanced.html"
    },
    {
      "src": "/courses",
      "dest": "/courses.html"
    },
    {
      "src": "/simple-login.html",
      "dest": "/simple-login.html"
    },
    {
      "src": "/dashboard-fixed.html",
      "dest": "/dashboard-fixed.html"
    },
    {
      "src": "/courses.html",
      "dest": "/courses.html"
    },
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
